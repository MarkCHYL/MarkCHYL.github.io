&lt;th&gt;3.x&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;&lt;tr&gt;
&lt;td&gt;compile&lt;/td&gt;
&lt;td&gt;implementation、api&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;provided&lt;/td&gt;
&lt;td&gt;compile only&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;apk&lt;/td&gt;
&lt;td&gt;runtime only&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;api&lt;/td&gt;
&lt;td&gt;api&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;&lt;/table&gt;
&lt;h3 id=&quot;替代关系：&quot;&gt;&lt;a href=&quot;#替代关系：&quot; class=&quot;headerlink&quot; title=&quot;替代关系：&quot;&gt;&lt;/a&gt;替代关系：&lt;/h3&gt;&lt;ul&gt;
